/*
Generated by Text-to-CAD:
A cube 20mm × 20mm × 20mm.
*/
@settings(defaultLengthUnit = mm)

size = 20

sketch = startSketchOn(XY)
profile = startProfile(sketch, at = [-size / 2, -size / 2])
  |> xLine(length = size)
  |> yLine(length = size)
  |> xLine(length = -size)
  |> close()

cube = extrude(profile, length = size)
